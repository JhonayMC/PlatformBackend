# 1-LEVANTAR PROYECTO EN PYTHON:
# Primero en la terminal en Vscode ejecutar:
# py -m venv venv
# 2-Ingresar a la carpeta 
# cd mym_plataforma
# 3-Ejecutar el script de las depencias 
# pip install -r ".\requirements.txt"
# 4- luego ejecutar comando 
# si esta  en la carpeta mym_plataforma
# python -m uvicorn main:app --port 8001 --reload
# 4- luego ejecutar comando para simular el api de mym debe ser en otro puerto
# python -m uvicorn main2:app --port 8002 --reload
# si no esta  en la carpeta mym_plataforma
# python -m uvicorn mym_plataforma.main:app --port 8001 --reload

